# --- TREEO HRMS Coolify Production Environment Variables Example ---
# Instructions: Copy these variables into your Coolify Dashboard -> Service Settings -> Environment Variables.
# Replace the generated/default values with your production passwords.

# The site domain where you will access your TREEO HR System (e.g. hr.treeo.id)
SITE_NAME=hr.treeo.id

# Secure database administrator password (MariaDB root password)
DB_ROOT_PASSWORD=your_secure_db_root_password_here

# Frappe Administrator password for first-time login
ADMIN_PASSWORD=your_secure_admin_password_here

# Image repository (defaults to official frappe/erpnext)
FRAPPE_IMAGE=frappe/erpnext

# Version tag (v15 is the stable release for production setups)
FRAPPE_VERSION=v15

# MariaDB version image (stable 10.6)
MARIADB_IMAGE=mariadb:10.6

# Redis version image
REDIS_IMAGE=redis:6.2-alpine
